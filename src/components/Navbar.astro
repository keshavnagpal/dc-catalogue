---
import { BRAND_NAME } from '../lib/config';
const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const links = [
  { name: 'Home', href: '/' },
  { name: 'Shop All', href: '/products' },
  { name: 'Bridal', href: '/categories/Bridal' },
  { name: 'Necklaces', href: '/categories/Necklaces' },
  { name: 'About', href: '/about' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center">
        <a href={`${basePath}/`} class="font-serif text-2xl font-bold text-brand-dark tracking-wide">
          {BRAND_NAME}
        </a>
      </div>
      
      {/* Desktop Menu */}
      <div class="hidden md:flex space-x-8">
        {links.map(link => (
          <a href={`${basePath}${link.href}`} class="text-gray-600 hover:text-brand-gold transition-colors duration-200 text-sm uppercase tracking-wider font-medium">
            {link.name}
          </a>
        ))}
      </div>

      {/* Mobile Menu Button - Minimal JS inline for simplicity in Astro */}
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-gray-600 hover:text-brand-dark focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    {/* Mobile Menu Panel */}
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-4 pt-2 border-t border-gray-100">
        {links.map(link => (
          <a href={`${basePath}${link.href}`} class="text-gray-600 hover:text-brand-gold text-sm uppercase tracking-wider font-medium px-2">
            {link.name}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>