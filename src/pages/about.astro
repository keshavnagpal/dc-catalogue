---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-5xl text-brand-dark mb-6">Our Story</h1>
      <div class="w-24 h-1 bg-brand-gold mx-auto"></div>
    </div>
    
    <div class="prose prose-lg mx-auto text-gray-600">
      <p class="mb-6">
        Welcome to our premium catalogue. We specialize in curating the finest artificial jewellery pieces that blend traditional craftsmanship with modern elegance.
      </p>
      <p class="mb-6">
        Our journey began with a simple vision: to provide luxurious, high-quality jewellery accessible to everyone. Every piece in our collection is carefully selected to ensure it meets our strict standards of design and durability.
      </p>
      <p>
        Whether you are looking for a statement bridal set or an elegant everyday necklace, we are here to help you find the perfect piece for your special moments.
      </p>
    </div>
  </div>
</Layout>