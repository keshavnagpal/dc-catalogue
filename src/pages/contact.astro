---
import Layout from '../layouts/Layout.astro';
import { WHATSAPP_NUMBER } from '../lib/config';
---

<Layout title="Contact Us">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-5xl text-brand-dark mb-6">Get in Touch</h1>
      <div class="w-24 h-1 bg-brand-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-1 gap-12 mt-12">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 text-center">
        <div class="w-16 h-16 mx-auto bg-brand-beige rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
          </svg>
        </div>
        <h3 class="font-serif text-2xl text-brand-dark mb-4">WhatsApp Us</h3>
        <p class="text-gray-500 mb-6">For the fastest response, reach out to us directly on WhatsApp.</p>
        <a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-dark text-white px-8 py-3 rounded-sm uppercase tracking-widest font-medium hover:bg-brand-gold transition">
          Message Now
        </a>
      </div>
    </div>
  </div>
</Layout>