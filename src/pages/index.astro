---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { fetchProducts } from '../lib/api';

const products = await fetchProducts();
const featuredProducts = products.filter(p => p.featured && p.status === 'active').slice(0, 4);
const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title="Home">
  {/* Hero Section */}
  <section class="relative bg-brand-beige overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 md:py-32 flex flex-col md:flex-row items-center">
      <div class="w-full md:w-1/2 z-10 text-center md:text-left mb-10 md:mb-0 pr-0 md:pr-12 mt-8 md:mt-0">
        <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl font-bold text-brand-dark leading-tight mb-4 sm:mb-6">
          Elegance in Every Detail
        </h1>
        <p class="text-base sm:text-lg text-gray-600 mb-8 sm:mb-10 max-w-lg mx-auto md:mx-0 px-4 sm:px-0 text-balance">
          Discover our curated collection of premium artificial jewellery, crafted for your most special moments.
        </p>
        <a href={`${basePath}/products`} class="inline-block bg-brand-dark text-white px-8 py-4 sm:py-4 rounded-full uppercase tracking-widest font-bold text-sm sm:text-base hover:bg-brand-gold transition shadow-xl hover:shadow-2xl active:scale-95 w-[90%] sm:w-auto mx-auto block">
          Explore Collection
        </a>
      </div>
      <div class="w-full md:w-1/2 relative px-4 sm:px-0">
        <div class="aspect-[4/5] sm:aspect-[4/5] bg-white rounded-3xl sm:rounded-2xl shadow-2xl overflow-hidden relative border-4 border-white">
          <img
            src="https://cpimg.tistatic.com/05935182/b/4/Fancy-Artificial-Jewellery.jpg"
            alt="Dhwani Collection Premium Jewellery"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 hover:scale-105"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Featured Products Section */}
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl text-brand-dark mb-2 sm:mb-4">Featured Pieces</h2>
        <p class="text-gray-500 uppercase tracking-widest text-xs sm:text-sm">Handpicked for you</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-8">
        {featuredProducts.length > 0 ? featuredProducts.map(product => (
          <ProductCard product={product} />
        )) : (
          <div class="col-span-2 lg:col-span-4 text-center py-10 text-gray-500">No featured products available.</div>
        )}
      </div>

      <div class="mt-12 sm:mt-16 text-center">
        <a href={`${basePath}/products`} class="inline-block border-b-2 border-brand-dark text-brand-dark uppercase tracking-widest font-bold text-sm sm:text-base hover:text-brand-gold hover:border-brand-gold transition pb-1 px-2">
          View All Products
        </a>
      </div>
    </div>
  </section>

  {/* Trust Section */}
  <section class="py-16 sm:py-24 bg-brand-beige/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 sm:gap-12 text-center">
        <div class="px-4 sm:px-0">
          <div class="w-14 h-14 sm:w-16 sm:h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-md mb-5 sm:mb-6">
            <svg class="w-6 h-6 sm:w-8 sm:h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg sm:text-xl mb-2 sm:mb-3 text-brand-dark">Premium Quality</h3>
          <p class="text-gray-500 text-xs sm:text-sm text-balance">Expertly crafted with the finest materials.</p>
        </div>
        <div class="px-4 sm:px-0">
          <div class="w-14 h-14 sm:w-16 sm:h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-md mb-5 sm:mb-6">
            <svg class="w-6 h-6 sm:w-8 sm:h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg sm:text-xl mb-2 sm:mb-3 text-brand-dark">Secure Ordering</h3>
          <p class="text-gray-500 text-xs sm:text-sm text-balance">Safe and seamless transactions via WhatsApp.</p>
        </div>
        <div class="px-4 sm:px-0">
          <div class="w-14 h-14 sm:w-16 sm:h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-md mb-5 sm:mb-6">
            <svg class="w-6 h-6 sm:w-8 sm:h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" />
            </svg>
          </div>
          <h3 class="font-serif text-lg sm:text-xl mb-2 sm:mb-3 text-brand-dark">Nationwide Delivery</h3>
          <p class="text-gray-500 text-xs sm:text-sm text-balance">Fast and reliable shipping across India.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>