---
import Layout from '../../layouts/Layout.astro';
import { fetchProducts } from '../../lib/api';
import { WHATSAPP_NUMBER } from '../../lib/config';
import type { Product } from '../../lib/types';

export async function getStaticPaths() {
  const products = await fetchProducts();
  return products.map(product => ({
    params: { sku: product.sku },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const isSoldOut = product.stock <= 0;
const whatsappLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(`Hi I want to order SKU ${product.sku} (${product.title})`)}`;
---

<Layout title={product.title} description={product.description}>
  <div class="max-w-7xl mx-auto px-0 sm:px-6 lg:px-8 py-0 sm:py-16">
    <div class="block mb-4 sm:mb-8 px-4 sm:px-0 pt-4 sm:pt-0">
      <a href={`${basePath}/products`} class="text-sm text-gray-500 hover:text-brand-gold transition uppercase tracking-wider font-semibold">&larr; Back to Shop</a>
    </div>

    <div class="flex flex-col md:flex-row gap-6 sm:gap-12 lg:gap-24">
      {/* Image Gallery */}
      <div class="md:w-1/2">
        <div class="flex flex-row overflow-x-auto sm:grid sm:grid-cols-1 gap-1 sm:gap-4 snap-x snap-mandatory sm:snap-none hide-scrollbar">
          {product.images.length > 0 ? (
            product.images.map((img, index) => {
              const imgSrc = img.startsWith('http') ? img : `${basePath}${img}`;
              return (
              <div class="w-full shrink-0 snap-start bg-gray-50 sm:rounded-2xl overflow-hidden sm:border border-gray-100 aspect-square sm:aspect-[4/5] relative">
                 {isSoldOut && index === 0 && (
                    <div class="absolute inset-0 bg-white/60 backdrop-blur-[2px] flex items-center justify-center z-10">
                      <span class="bg-brand-dark/90 text-white px-6 py-2.5 text-sm font-bold tracking-widest uppercase rounded-full shadow-lg">
                        Sold Out
                      </span>
                    </div>
                  )}
                <img src={imgSrc} alt={`${product.title} - Image ${index + 1}`} class="w-full h-full object-cover" />
              </div>
              )
            })
          ) : (
            <div class="w-full shrink-0 snap-start bg-gray-50 sm:rounded-2xl overflow-hidden sm:border border-gray-100 aspect-square sm:aspect-[4/5] relative">
              {isSoldOut && (
                <div class="absolute inset-0 bg-white/60 backdrop-blur-[2px] flex items-center justify-center z-10">
                  <span class="bg-brand-dark/90 text-white px-6 py-2.5 text-sm font-bold tracking-widest uppercase rounded-full shadow-lg">
                    Sold Out
                  </span>
                </div>
              )}
              <img src={`${basePath}/images/placeholder.jpg`} alt="No image available" class="w-full h-full object-cover opacity-80" />
            </div>
          )}
        </div>
      </div>

      {/* Product Details */}
      <div class="md:w-1/2 md:sticky md:top-24 h-max px-5 sm:px-0 pt-4 sm:pt-0 pb-12 sm:pb-0">
        <div class="mb-2">
          <span class="text-[10px] sm:text-xs text-brand-gold uppercase tracking-widest font-bold">{product.category}</span>
        </div>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl text-brand-dark mb-3 sm:mb-4 leading-tight">{product.title}</h1>
        <div class="text-2xl sm:text-3xl font-semibold text-brand-dark mb-6">₹{product.price.toLocaleString('en-IN')}</div>

        <div class="prose prose-sm sm:prose-base text-gray-600 mb-8 leading-relaxed">
          <p>{product.description || "No description provided."}</p>
        </div>

        <div class="mb-8 space-y-2">
          <div class="text-sm text-gray-500 flex items-center">
            <span class="w-24">SKU:</span>
            <span class="text-brand-dark font-medium">{product.sku}</span>
          </div>
          <div class="text-sm text-gray-500 flex items-center">
             <span class="w-24">Availability:</span>
            <span class={`font-medium ${isSoldOut ? 'text-red-500' : 'text-green-600'}`}>
              {isSoldOut ? 'Sold Out' : `${product.stock} in stock`}
            </span>
          </div>
        </div>

        {/* Action Button - Sticky on mobile bottom, normal on desktop */}
        <div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-sm sm:static sm:translate-x-0 sm:w-full sm:max-w-none z-50 pointer-events-none sm:pointer-events-auto">
          {isSoldOut ? (
            <button disabled class="pointer-events-auto w-full bg-gray-200 text-gray-500 py-4 rounded-full text-sm uppercase tracking-widest font-bold cursor-not-allowed shadow-xl">
              Currently Unavailable
            </button>
          ) : (
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="pointer-events-auto block w-full text-center bg-brand-dark text-white py-4 rounded-full text-sm uppercase tracking-widest font-bold hover:bg-brand-gold transition shadow-[0_8px_30px_rgba(0,0,0,0.2)] active:scale-[0.98]">
              Order via WhatsApp
            </a>
          )}
        </div>

        <div class="mt-8 pt-8 border-t border-gray-100 mb-32 sm:mb-0">
          <h3 class="text-sm font-bold text-brand-dark uppercase tracking-wider mb-3">Shipping & Returns</h3>
          <p class="text-xs sm:text-sm text-gray-500 mb-2">Free shipping on orders over ₹1,000.</p>
          <p class="text-xs sm:text-sm text-gray-500">For inquiries, please use the WhatsApp button above.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>